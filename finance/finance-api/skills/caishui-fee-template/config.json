{
  "name": "caishui-fee-template-skill",
  "version": "1.0.0",
  "description": "财税通费用模板批量添加工具 - 自动将Excel中的费用科目添加到系统",
  "author": "AI Assistant",
  "license": "MIT",
  "keywords": [
    "财税通",
    "费用模板",
    "自动化",
    "批量添加",
    "浏览器自动化",
    "CDP"
  ],
  "main": "scripts/add_fee_templates.py",
  "entry_point": "python3 scripts/add_fee_templates.py",
  "requirements": [
    "pandas",
    "requests",
    "websocket-client",
    "openpyxl"
  ],
  "python_version": ">=3.8",
  "browser": {
    "type": "Edge",
    "debug_port": 9223,
    "required": true
  },
  "system_requirements": {
    "platform": ["macOS", "Windows", "Linux"],
    "dependencies": [
      "Microsoft Edge 或 Google Chrome",
      "Python 3.8+",
      "pip"
    ]
  },
  "usage": {
    "prerequisites": [
      "1. 启动 Edge 浏览器调试模式",
      "2. 登录财税通系统并打开费用模板页面",
      "3. 准备Excel文件（包含'一级科目'和'二级科目'列）"
    ],
    "command": "python3 scripts/add_fee_templates.py [excel文件路径]",
    "example": "python3 scripts/add_fee_templates.py /Users/tang/Desktop/费用模板.xlsx"
  },
  "api_endpoints": [
    {
      "name": "queryFeeTemplate",
      "method": "GET",
      "url": "/api/bill/feeTemplate/queryFeeTemplate",
      "description": "查询费用模板列表"
    },
    {
      "name": "getFeeTemplateById",
      "method": "GET",
      "url": "/api/bill/feeTemplate/getFeeTemplateById",
      "description": "查询单个费用模板详情（含完整字段）"
    },
    {
      "name": "addFeeTemplate",
      "method": "POST",
      "url": "/api/bill/feeTemplate/addFeeTemplate",
      "description": "添加费用模板"
    }
  ],
  "documentation": {
    "readme": "README.md",
    "examples": "examples/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tang730125633/caishui-fee-template-skill"
  },
  "created_at": "2026-03-10",
  "updated_at": "2026-03-10"
}